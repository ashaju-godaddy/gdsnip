# API Configuration
GDSNIP_PORT=8080
GDSNIP_DATABASE_URL=postgres://gdsnip:gdsnip@localhost:5432/gdsnip?sslmode=disable
GDSNIP_JWT_SECRET=change-this-to-a-secure-random-string-in-production
GDSNIP_JWT_EXPIRY=168h
